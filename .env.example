# ============================================================
# AuditDrop — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# ----------------------------------------------------------
# Firebase Client SDK (public — safe to expose in browser)
# Get these from: Firebase Console > Project Settings > General
# ----------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ----------------------------------------------------------
# Firebase Admin SDK (SERVER-SIDE ONLY — never expose these)
# Get these from: Firebase Console > Project Settings > Service Accounts
# > Generate new private key
# ----------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Paste the full private key — keep the quotes and \n characters as-is
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------
# Optional: ScreenshotOne API (free tier: 100 screenshots/month)
# Get your key at: https://screenshotone.com
# Leave empty to disable screenshot thumbnails.
# ----------------------------------------------------------
SCREENSHOTONE_API_KEY=

# ----------------------------------------------------------
# Optional: Google PageSpeed Insights API key
# Only needed if you exceed 25,000 requests/day (free quota).
# Get a key at: https://developers.google.com/speed/docs/insights/v5/get-started
# ----------------------------------------------------------
PSI_API_KEY=

# ----------------------------------------------------------
# Optional: Google Places API key (for GBP audits)
# Enables Google Business Profile audit when running reports.
# Get a key at: https://developers.google.com/maps/documentation/places/web-service/get-api-key
# ----------------------------------------------------------
GOOGLE_PLACES_API_KEY=
